class Inventory:
    def __init__(self, gold):
        self.__gold = gold

    def get_gold(self):
        return f"В кошеле: {self.__gold} проклятых монет"

    def change_gold(self, amount):
        if self.__gold + amount < 0:
            print("Недостаточно золота для сделки!")
        else:
            self.__gold += amount

inventory = Inventory(100)
print(inventory.get_gold())

inventory.change_gold(50)
print(inventory.get_gold())

inventory.change_gold(-70)
print(inventory.get_gold())

inventory.change_gold(-200)
print(inventory.get_gold())
