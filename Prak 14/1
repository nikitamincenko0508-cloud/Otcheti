import random

rows = 5
cols = 4
nested_list = []

for _ in range(rows):
    row_list = [random.randint(0, 100) for _ in range(cols)]
    nested_list.append(row_list)

print("Созданный вложенный список:")
for i, row in enumerate(nested_list):
    print(f"Индекс строки {i}: {row}")

max_value = -1
max_row_index = 0
max_col_index = 0

for i in range(rows):
    for j in range(cols):
        if nested_list[i][j] > max_value:
            max_value = nested_list[i][j]
            max_row_index = i
            max_col_index = j

print(f"\nМаксимальный элемент: {max_value}")
print(f"Расположен в строке: {max_row_index}, позиции в строке: {max_col_index}")
