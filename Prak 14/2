import random

rows = 5
cols = 4
nested_list = []

for _ in range(rows):
    row_list = [random.randint(0, 100) for _ in range(cols)]
    nested_list.append(row_list)

print("Созданный вложенный список:")
for i, row in enumerate(nested_list):
    print(f"Индекс строки {i}: {row}")

sum_of_rows = []
total_sum = 0
max_row_sum = -1
max_row_index = 0

for i in range(rows):
    row_sum = sum(nested_list[i])
    sum_of_rows.append(row_sum)
    total_sum += row_sum

    if row_sum > max_row_sum:
        max_row_sum = row_sum
        max_row_index = i

print("\nСуммы по строкам:")
for i, row_sum in enumerate(sum_of_rows):
    print(f"Сумма строки {i}: {row_sum}")

print(f"\nОбщая сумма всех элементов: {total_sum}")
print(f"Строка с максимальной суммой: {max_row_index} (сумма: {max_row_sum})")
