prices_str = '100 50 200 150 75 300'

prices = [int(price) for price in prices_str.split()]

print(f"Исходный список цен: {prices}")

max_price = max(prices)
print(f"Максимальная цена: {max_price}")

prices.remove(max_price)
print(f"После удаления самого дорогого товара: {prices}")

new_price = max_price * 0.5
prices.append(int(new_price))
print(f"После добавления товара со скидкой ({int(new_price)}): {prices}")

prices.sort()
print(f"После сортировки: {prices}")

prices_str_result = ', '.join(str(price) for price in prices)
print(f"Цены через запятую: {prices_str_result}")

average_price = sum(prices) / len(prices)
print(f"Средняя цена: {average_price:.2f}")
