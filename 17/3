def is_prime(num):
    if num <= 1:
        return False
    if num == 2:
        return True
    if num % 2 == 0:
        return False
    i = 3
    while i * i <= num:
        if num % i == 0:
            return False
        i += 2
    return True

def get_next_prime(num):
    candidate = num + 1
    while True:
        if is_prime(candidate):
            return candidate
        candidate += 1

print(get_next_prime(6))
print(get_next_prime(7))
print(get_next_prime(14))
